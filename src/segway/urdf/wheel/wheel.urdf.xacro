<?xml version="1.0"?>
<robot xmlns:xacro="http://ros.org/wiki/xacro">

  <xacro:include filename="$(find segway)/urdf/wheel/wheel.transmission.xacro"/>
  <xacro:include filename="$(find segway)/urdf/wheel/wheel.gazebo.xacro"/>
  
  <xacro:macro name="rear_wheel_v0" params="prefix parent *joint_origin *joint_axis">
	<joint name="${prefix}_wheel_joint" type="continuous">
	  <xacro:insert_block name="joint_origin"/>
	  <parent link="${parent}"/>
	  <child link="${prefix}_wheel_link"/>
	  <xacro:insert_block name="joint_axis"/>
	</joint>

	<link name="${prefix}_wheel_link">
	  <visual>
		<geometry>
		  <mesh filename="file://$(find segway)/models/segway/meshes/DAE/wheel/wheel_sim.dae"/>
		</geometry>
	  </visual>
	  <collision>
		<geometry>
		  <mesh filename="file://$(find segway)/models/segway/meshes/STL/wheel/wheel_sim.stl"/>
		</geometry>
	  </collision>
	  <inertial>
		<origin xyz="0 0.106 0"/>
		<mass value="0.5"/>
		<inertia ixx="0.011862" ixy="0" ixz="0" iyy="0.022022" iyz="0" izz="0.011862"/>
	  </inertial>
	</link>
  </xacro:macro>
  
</robot>

