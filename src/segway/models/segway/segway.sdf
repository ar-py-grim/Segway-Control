<sdf version='1.11'>
  <model name='segway'>
    <link name='base_footprint'>
      <inertial>
        <pose>0.0054 0 0.5970 0 0 0</pose>
        <mass>80.004999999999995</mass>
        <inertia>
          <ixx>35.478547</ixx>
          <ixy>0.000003</ixy>
          <ixz>-0.416935</ixz>
          <iyy>35.553746</iyy>
          <iyz>0.000012</iyz>
          <izz>1.448630</izz>
        </inertia>
      </inertial>
      <collision name='base_footprint_fixed_joint_lump__base_link_collision'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://segway/meshes/STL/base/body.stl</uri>
          </mesh>
        </geometry>
        <surface>
          <contact>
            <ode/>
          </contact>
          <friction>
            <ode>
              <mu>0.050000000000000003</mu>
              <mu2>0.050000000000000003</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name='base_footprint_fixed_joint_lump__base_link_visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://segway/meshes/DAE/base/body.dae</uri>
          </mesh>
        </geometry>
      </visual>
      <self_collide>false</self_collide>
      <sensor name='imu_sensor' type='imu'>
        <always_on>true</always_on>
        <update_rate>100</update_rate>
        <topic>/imu</topic>
        <imu>
          <angular_velocity>
            <x>
              <noise type='gaussian'>
                <mean>0</mean>
                <stddev>0</stddev>
              </noise>
            </x>
            <y>
              <noise type='gaussian'>
                <mean>0</mean>
                <stddev>0</stddev>
              </noise>
            </y>
            <z>
              <noise type='gaussian'>
                <mean>0</mean>
                <stddev>0</stddev>
              </noise>
            </z>
          </angular_velocity>
          <linear_acceleration>
            <x>
              <noise type='gaussian'>
                <mean>0</mean>
                <stddev>0</stddev>
              </noise>
            </x>
            <y>
              <noise type='gaussian'>
                <mean>0</mean>
                <stddev>0</stddev>
              </noise>
            </y>
            <z>
              <noise type='gaussian'>
                <mean>0</mean>
                <stddev>0</stddev>
              </noise>
            </z>
          </linear_acceleration>
        </imu>
        <pose>0 0 0.29732199999999998 0 0 0</pose>
        <gz_frame_id>imu_link</gz_frame_id>
      </sensor>
    </link>
    <joint name='left_wheel_joint' type='revolute'>
      <pose relative_to='base_footprint'>0 -0.238506 0.29732199999999998 0 0 -3.141592567179587</pose>
      <parent>base_footprint</parent>
      <child>left_wheel_link</child>
      <axis>
        <xyz>0 -1 0</xyz>
        <limit>
          <lower>-inf</lower>
          <upper>inf</upper>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>
    <link name='left_wheel_link'>
      <pose relative_to='left_wheel_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0.106 0 0 0 0</pose>
        <mass>0.5</mass>
        <inertia>
          <!-- <ixx>0.0011900000000000001</ixx> -->
          <ixx>0.011862</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <!-- <iyy>0.0022000000000000001</iyy> -->
          <iyy>0.022022</iyy>
          <iyz>0</iyz>
          <!-- <izz>0.0011900000000000001</izz> -->
          <izz>0.011862</izz>
        </inertia>
      </inertial>
      <collision name='left_wheel_link_collision'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://segway/meshes/STL/wheel/wheel_sim.stl</uri>
          </mesh>
        </geometry>
        <surface>
          <contact>
            <ode/>
          </contact>
          <friction>
            <ode>
              <mu>0.80000000000000004</mu>
              <mu2>0.80000000000000004</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name='left_wheel_link_visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://segway/meshes/DAE/wheel/wheel_sim.dae</uri>
          </mesh>
        </geometry>
      </visual>
      <self_collide>false</self_collide>
    </link>
    <joint name='right_wheel_joint' type='revolute'>
      <pose relative_to='base_footprint'>0 0.238506 0.29732199999999998 0 0 0</pose>
      <parent>base_footprint</parent>
      <child>right_wheel_link</child>
      <axis>
        <xyz>0 1 0</xyz>
        <limit>
          <lower>-inf</lower>
          <upper>inf</upper>
        </limit>
        <dynamics>
          <spring_reference>0</spring_reference>
          <spring_stiffness>0</spring_stiffness>
        </dynamics>
      </axis>
    </joint>
    <link name='right_wheel_link'>
      <pose relative_to='right_wheel_joint'>0 0 0 0 0 0</pose>
      <inertial>
        <pose>0 0.106 0 0 0 0</pose>
        <mass>0.5</mass>
        <inertia>
          <ixx>0.0011900000000000001</ixx>
          <ixy>0</ixy>
          <ixz>0</ixz>
          <iyy>0.0022000000000000001</iyy>
          <iyz>0</iyz>
          <izz>0.0011900000000000001</izz>
        </inertia>
      </inertial>
      <collision name='right_wheel_link_collision'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://segway/meshes/STL/wheel/wheel_sim.stl</uri>
          </mesh>
        </geometry>
        <surface>
          <contact>
            <ode/>
          </contact>
          <friction>
            <ode>
              <mu>0.80000000000000004</mu>
              <mu2>0.80000000000000004</mu2>
            </ode>
          </friction>
        </surface>
      </collision>
      <visual name='right_wheel_link_visual'>
        <pose>0 0 0 0 0 0</pose>
        <geometry>
          <mesh>
            <scale>1 1 1</scale>
            <uri>model://segway/meshes/DAE/wheel/wheel_sim.dae</uri>
          </mesh>
        </geometry>
      </visual>
      <self_collide>false</self_collide>
    </link>
    <plugin name='gz::sim::systems::DiffDrive' filename='gz-sim-diff-drive-system'>
      <left_joint>left_wheel_joint</left_joint>
      <right_joint>right_wheel_joint</right_joint>
      <wheel_separation>0.477012</wheel_separation>
      <wheel_radius>0.28</wheel_radius>
      <!-- <max_wheel_torque>10.0</max_wheel_torque>
      <max_wheel_acceleration>10.0</max_wheel_acceleration> -->
      <max_wheel_torque>5.0</max_wheel_torque>      
      <max_wheel_acceleration>5.0</max_wheel_acceleration> 
      <topic>/cmd_vel</topic>
      <odom_topic>/odom</odom_topic>
      <frame_id>odom</frame_id>
      <child_frame_id>base_link</child_frame_id>
      <publish_odom>true</publish_odom>
      <publish_odom_tf>true</publish_odom_tf>
    </plugin>
    <plugin name='gz::sim::systems::JointStatePublisher' filename='gz-sim-joint-state-publisher-system'>
      <joint_name>left_wheel_joint</joint_name>
      <joint_name>right_wheel_joint</joint_name>
    </plugin>
    <frame name='imu_joint' attached_to='base_link'>
      <pose>0 0 0.29732199999999998 0 0 0</pose>
    </frame>
    <frame name='imu_link' attached_to='imu_joint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <frame name='base_link_joint' attached_to='base_footprint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
    <frame name='base_link' attached_to='base_link_joint'>
      <pose>0 0 0 0 0 0</pose>
    </frame>
  </model>
</sdf>
